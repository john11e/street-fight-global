; Engine configuration file.
; Generated for: Godot 4.3 — Street Fight Global
; Edit via: Project > Project Settings

config_version=5

[application]

config/name="Street Fight Global"
config/description="Commercial-grade 10-player street brawler with Web3 economy"
config/version="1.0.0"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://assets/ui/icon.png"
boot_splash/image="res://assets/ui/splash.png"
boot_splash/bg_color=Color(0.05, 0.05, 0.05, 1)

[autoload]

; ORDER MATTERS — AuthManager first, GameState second
GameState="*res://autoloads/game_state.gd"
AuthManager="*res://autoloads/auth_manager.gd"
NetworkManager="*res://autoloads/network_manager.gd"
EconomyManager="*res://autoloads/economy_manager.gd"
ArenaManager="*res://autoloads/arena_manager.gd"
VFXManager="*res://autoloads/vfx_manager.gd"
CameraManager="*res://autoloads/camera_manager.gd"
UIManager="*res://autoloads/ui_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

